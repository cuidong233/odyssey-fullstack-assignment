{
  "name": "odyssey-restaurant-ops",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev:backend": "pnpm --filter @repo/backend dev",
    "dev:dashboard": "pnpm --filter @repo/dashboard dev",
    "db:push": "pnpm --filter @repo/backend db:push",
    "db:seed": "pnpm --filter @repo/backend seed",
    "db:setup": "pnpm db:push && pnpm db:seed",
    "gen:contract": "pnpm --filter @repo/backend gen:openapi && pnpm --filter @repo/types gen && pnpm --filter @repo/api-client gen",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  }
}
